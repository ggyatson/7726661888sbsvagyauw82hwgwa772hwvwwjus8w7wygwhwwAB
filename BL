}

local Shoot = ReplicatedStorage.Packages.Knit.Services.ControlService.RE.Shoot
local visualGui = player.PlayerGui:WaitForChild("Visual")
local shootingElement = visualGui:WaitForChild("Shooting")
local bar = shootingElement:FindFirstChild("Bar")

local shotPowerMap = {
    Perfect  = 1.00,
    Great    = 0.95,
    Good     = 0.90,
    Mediocre = 0.80,
}

local function getRandomShotPower()
    if #Config.randomShotTypes == 0 then return 1.0 end
    return shotPowerMap[Config.randomShotTypes[math.random(1, #Config.randomShotTypes)]] or 1.0
end

local function rageGreenShoot()
    local char = player.Character
    if char and char:FindFirstChild("Basketball") and bar then
        bar:TweenSize(UDim2.fromScale(1,1), Enum.EasingDirection.Out, Enum.EasingStyle.Linear, 0.001, true)
        bar.Size = UDim2.fromScale(1,1)
    end
end

task.spawn(function()
    local mainGui = player.PlayerGui:WaitForChild("Main", 10)
    if not mainGui then return end
    local holder = mainGui:FindFirstChild("Mobile") and mainGui.Mobile:FindFirstChild("Holder")
    local btn = holder and holder:FindFirstChild("Shoot")
    if not btn then return end
    for _, e in ipairs({"MouseButton1Click", "MouseButton1Down", "Activated"}) do
        pcall(function()
            btn[e]:Connect(function()
                if Config.autoRageGreenEnabled then rageGreenShoot() end
            end)
        end)
    end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if not gp and input.KeyCode == Enum.KeyCode.E and Config.autoRageGreenEnabled then
        rageGreenShoot()
    end
end)

local visibleConn = nil

local function anyAutoTimingOn()
    return Config.autoPerfectEnabled or Config.autoGreatEnabled
        or Config.autoGoodEnabled or Config.autoMediocreEnabled
        or Config.randomShotEnabled
end

local function enableAutoShoot()
    if visibleConn then return end
    visibleConn = shootingElement:GetPropertyChangedSignal("Visible"):Connect(function()
        if shootingElement.Visible == true then
            task.wait(0.25)
            local power
            if Config.randomShotEnabled and #Config.randomShotTypes > 0 then
                power = getRandomShotPower()
            elseif Config.autoPerfectEnabled  then power = 1.00
            elseif Config.autoGreatEnabled    then power = 0.95
            elseif Config.autoGoodEnabled     then power = 0.90
            elseif Config.autoMediocreEnabled then power = 0.80
            end
            if power then Shoot:FireServer(power) end
        end
    end)
end

local function refreshAutoShoot()
    if anyAutoTimingOn() then
        enableAutoShoot()
    else
        if visibleConn then visibleConn:Disconnect(); visibleConn = nil end
    end
end

local cframeConn = nil

local function startCframeSpeed()
    if cframeConn then cframeConn:Disconnect() end
    cframeConn = RunService.RenderStepped:Connect(function()
        if not Config.cframeSpeedEnabled then return end
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not root or not hum then return end
        local mv = hum.MoveDirection
        if mv.Magnitude > 0 then
            root.CFrame = root.CFrame + mv.Unit * Config.cframeSpeedAmount
        end
    end)
end

local function stopCframeSpeed()
    if cframeConn then cframeConn:Disconnect(); cframeConn = nil end
end

player.CharacterAdded:Connect(function()
    task.wait(1)
    if Config.cframeSpeedEnabled then startCframeSpeed() end
end)

local removedTextures = {}
local textureConn = nil

local function processObject(v)
    if v:IsA("Texture") or v:IsA("Decal") or v:IsA("SpecialMesh") or v:IsA("SurfaceAppearance") then
        local stored = { obj = v, trans = v.Transparency }
        if v:IsA("Texture") or v:IsA("Decal") then
            stored.texId = v.Texture
        end
        table.insert(removedTextures, stored)
        pcall(function() v.Transparency = 1 end)
        pcall(function()
            if v:IsA("Texture") or v:IsA("Decal") then
                v.Texture = ""
            end
        end)
        if v:IsA("SurfaceAppearance") then
            pcall(function() v:Destroy() end)
        end
    elseif v:IsA("BasePart") then
        local stored = { obj = v, mat = v.Material, color = v.Color }
        table.insert(removedTextures, stored)
        pcall(function()
            v.Material = Enum.Material.SmoothPlastic
        end)
    end
end

local function removeTextures()
    for _, v in ipairs(workspace:GetDescendants()) do
        pcall(function() processObject(v) end)
    end
    textureConn = workspace.DescendantAdded:Connect(function(v)
        if Config.removeTexturesEnabled then
            task.wait()
            pcall(function() processObject(v) end)
        end
    end)
end

local function restoreTextures()
    if textureConn then textureConn:Disconnect(); textureConn = nil end
    for _, t in ipairs(removedTextures) do
        pcall(function()
            if t.trans ~= nil then t.obj.Transparency = t.trans end
            if t.texId  ~= nil then t.obj.Texture = t.texId end
            if t.mat    ~= nil then t.obj.Material = t.mat end
            if t.color  ~= nil then t.obj.Color = t.color end
        end)
    end
    removedTextures = {}
end

