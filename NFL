local function ensureFolders()
    pcall(function()
        if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
        if not isfolder(CONFIG_PATH) then makefolder(CONFIG_PATH) end
    end)
end

local function listConfigs()
    local names = {}
    pcall(function()
        ensureFolders()
        for _, path in ipairs(listfiles(CONFIG_PATH)) do
            local name = path:match("([^/\\]+)%.json$")
            if name then table.insert(names, name) end
        end
    end)
    return #names > 0 and names or {"No configs"}
end

local function saveConfig(name)
    if not name or name == "" then
        Rayfield:Notify({ Title = "Config", Content = "Enter a config name first.", Duration = 3, Image = "alert-circle" })
        return
    end
    local data = {}
    for key, element in pairs(Elements) do
        pcall(function()
            data[key] = element.CurrentValue
        end)
    end
    local ok, err = pcall(function()
        ensureFolders()
        writefile(CONFIG_PATH .. "/" .. name .. ".json", HttpService:JSONEncode(data))
    end)
    if ok then
        Rayfield:Notify({ Title = "Config Saved", Content = "Saved as: " .. name, Duration = 3, Image = "check-circle" })
    else
        Rayfield:Notify({ Title = "Save Failed", Content = tostring(err), Duration = 4, Image = "alert-circle" })
    end
end

local function loadConfig(name)
    if not name or name == "" or name == "No configs" then
        Rayfield:Notify({ Title = "Config", Content = "Select a valid config.", Duration = 3, Image = "alert-circle" })
        return
    end
    local ok, err = pcall(function()
        local content = readfile(CONFIG_PATH .. "/" .. name .. ".json")
        local data = HttpService:JSONDecode(content)
        for key, value in pairs(data) do
            pcall(function()
                if Elements[key] then
                    Elements[key]:Set(value)
                end
            end)
        end
    end)
    if ok then
        Rayfield:Notify({ Title = "Config Loaded", Content = "Loaded: " .. name, Duration = 3, Image = "refresh-cw" })
    else
        Rayfield:Notify({ Title = "Load Failed", Content = tostring(err), Duration = 4, Image = "alert-circle" })
    end
end

local function deleteConfig(name)
    if not name or name == "" or name == "No configs" then
        Rayfield:Notify({ Title = "Config", Content = "Select a valid config to delete.", Duration = 3, Image = "alert-circle" })
        return
    end
    local ok = pcall(function()
        delfile(CONFIG_PATH .. "/" .. name .. ".json")
    end)
    if ok then
        Rayfield:Notify({ Title = "Config Deleted", Content = "Deleted: " .. name, Duration = 3, Image = "check-circle" })
    else
        Rayfield:Notify({ Title = "Delete Failed", Content = "Could not delete config.", Duration = 3, Image = "alert-circle" })
    end
end

