    Name = "CFrame Speed",
    CurrentValue = false,
    Flag = "CframeSpeed",
    Callback = function(v)
        cframeSpeedEnabled = v
        if v then
            if cframeConnection then cframeConnection:Disconnect() end
            cframeConnection = RunService.RenderStepped:Connect(function()
                if not cframeSpeedEnabled then return end
                local char = plr.Character
                if not char then return end
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                if not root or not hum then return end
                local mv = hum.MoveDirection
                if mv.Magnitude > 0 then
                    root.CFrame = root.CFrame + mv.Unit * cframeSpeedAmount
                end
            end)
        else
            if cframeConnection then cframeConnection:Disconnect(); cframeConnection = nil end
        end
    end,
})

