local function setPullActive(active)
    pullButtonActive = active
    isPullingBall    = active
    if active then
        pullButton.BackgroundColor3 = Color3.fromRGB(20, 80, 200)
        pullStroke.Color = Color3.fromRGB(80, 150, 255)
        pullDot.BackgroundColor3   = Color3.fromRGB(80, 150, 255)
    else
        pullButton.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
        pullStroke.Color = Color3.fromRGB(100, 100, 120)
        pullDot.BackgroundColor3   = Color3.fromRGB(80, 80, 100)
    end
end

local function setLegitActive(active)
    legPullButtonActive = active
    isLegitPulling      = active
    if active then
        legPullButton.BackgroundColor3 = Color3.fromRGB(20, 130, 80)
        legStroke.Color = Color3.fromRGB(60, 220, 120)
        legDot.BackgroundColor3        = Color3.fromRGB(60, 220, 120)
    else
        legPullButton.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
        legStroke.Color = Color3.fromRGB(100, 100, 120)
        legDot.BackgroundColor3        = Color3.fromRGB(80, 80, 100)
    end
end

pullButton.MouseButton1Down:Connect(function()
    if not pullVectorEnabled then return end
    setPullActive(true)
    task.spawn(function()
        while isPullingBall and pullVectorEnabled do teleportToBall(); task.wait(0.05) end
    end)
end)
pullButton.MouseButton1Up:Connect(function() setPullActive(false) end)

legPullButton.MouseButton1Down:Connect(function()
    if not smoothPullEnabled then return end
    setLegitActive(true)
    task.spawn(function()
        while isLegitPulling and smoothPullEnabled do smoothTeleportToBall(); task.wait(0.01) end
    end)
end)
legPullButton.MouseButton1Up:Connect(function() setLegitActive(false) end)

UserInputService.TouchEnded:Connect(function()
    if pullButtonActive   then setPullActive(false)   end
    if legPullButtonActive then setLegitActive(false) end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == pullKeybind and pullVectorEnabled then
        setPullActive(true)
        task.spawn(function()
            while isPullingBall and pullVectorEnabled do teleportToBall(); task.wait(0.05) end
        end)
    end
    if input.KeyCode == legitPullKeybind and smoothPullEnabled then
        setLegitActive(true)
        task.spawn(function()
            while isLegitPulling and smoothPullEnabled do smoothTeleportToBall(); task.wait(0.01) end
        end)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == pullKeybind      then setPullActive(false)   end
    if input.KeyCode == legitPullKeybind then setLegitActive(false)  end
end)

